		[ -z "$tmprx" ] && tmprx=0
		echo "$tmprx"
	elif [ $1 == "get_tx_bytes" ] ;then
		[ ! -f "${dir}bandix_cache.json" ] && usage update
		local mac="$2"
		local tmptx=$(/usr/bin/jq -r --arg mac "$mac" '.d[] | select(.mac | ascii_downcase == ($mac | ascii_downcase)) | .t_tx_b // 0' ${dir}bandix_cache.json 2>/dev/null | head -n1)
		[ -z "$tmptx" ] && tmptx=0
		echo "$tmptx"
	elif [ $1 == "down" ] ;then
		# Bandix Ŕç¬Ŕíîš«íšÉćŠĽ░ŠŹ«šöčňĹŻňĹĘŠťč´╝îŠŚáÚťÇŠëőňŐĘňłáÚÖĄ
		return
